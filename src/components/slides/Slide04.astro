---
// Slide 04 — Architecture globale
---
<section>
  <span class="slide-tag">Architecture</span>
  <h2>Vue d'ensemble <span class="accent">système</span></h2>

  <div class="flow" style="margin-top:24px; justify-content:center; gap:10px;">
    <div class="flow-box" style="border-color:var(--blue);">
      Browser<br /><small>Next.js · React 19</small>
    </div>
    <div class="arrow">⇄</div>
    <div class="flow-box hi">
      server.ts<br /><small>HTTP + WebSocket</small>
    </div>
    <div class="arrow">⇄</div>
    <div class="flow-box" style="border-color:var(--green);">
      SQLite / Prisma<br /><small>Users · Debates · Analysis</small>
    </div>
    <div class="arrow">⇄</div>
    <div class="flow-box" style="border-color:var(--red);">
      Groq API<br /><small>Llama 3.3 70B</small>
    </div>
  </div>

  <div style="margin-top:28px;">
    <p style="font-size:.55em; color:#888; text-align:center; margin-bottom:10px;">ROUTES API</p>
    <div class="flow" style="justify-content:center; gap:8px;">
      <div class="flow-box" style="font-size:.55em;">/api/auth</div>
      <div class="flow-box" style="font-size:.55em;">/api/debates</div>
      <div class="flow-box hi" style="font-size:.55em;">/api/ai/evaluate</div>
      <div class="flow-box hi" style="font-size:.55em;">/api/ai/opponent</div>
      <div class="flow-box hi" style="font-size:.55em;">/api/ai/hint</div>
      <div class="flow-box hi" style="font-size:.55em;">/api/ai/factcheck</div>
      <div class="flow-box" style="font-size:.55em;">/api/leaderboard</div>
    </div>
  </div>

  <div style="margin-top:20px;">
    <p style="font-size:.55em; color:#888; text-align:center; margin-bottom:10px;">WEBSOCKET — Temps réel</p>
    <div class="flow" style="justify-content:center; gap:8px;">
      <div class="flow-box" style="font-size:.55em;">join</div>
      <div class="arrow" style="font-size:.9em;">→</div>
      <div class="flow-box" style="font-size:.55em;">message</div>
      <div class="arrow" style="font-size:.9em;">→</div>
      <div class="flow-box" style="font-size:.55em;">turn_changed</div>
      <div class="arrow" style="font-size:.9em;">→</div>
      <div class="flow-box" style="font-size:.55em;">new_message</div>
      <div class="arrow" style="font-size:.9em;">→</div>
      <div class="flow-box" style="font-size:.55em;">debate_ended</div>
    </div>
  </div>
</section>
